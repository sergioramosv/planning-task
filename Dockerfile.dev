# Development Dockerfile with watch polling
FROM node:22-alpine

WORKDIR /app

# Install build tools (chokidar comes via npm)
RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    git \
    curl

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev)
RUN npm install

# Copy application code
COPY . .

# Create volume mount point
VOLUME ["/app"]

# Expose port for Next.js
EXPOSE 3300

# Health check
HEALTHCHECK --interval=10s --timeout=3s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:3300 || exit 1

# Environment variables for polling-based watch
ENV WATCHPACK_POLLING=true
ENV CHOKIDAR_USEPOLLING=true
ENV CHOKIDAR_INTERVAL=100

# Start development server with polling for file changes
CMD ["npm", "run", "dev"]
